# ── Owner / JWT ──────────────────────────────────────────
OWNER_USERNAME=admin
OWNER_PASSWORD=changeme123          # hashed on first run
JWT_SECRET=replace_with_64_char_random_string

# ── Script encryption ────────────────────────────────────
SCRIPT_AES_KEY=replace_with_32_char_hex_key   # openssl rand -hex 16

# ── Server ───────────────────────────────────────────────
PORT=4040
BASE_URL=https://ojojojaojooj-production.up.railway.app/     # change to your domain in prod

# ── Discord bot ──────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id
DISCORD_OWNER_ROLE_ID=your_owner_role_id   # who can run owner commands
DISCORD_MEMBER_ROLE_ID=your_member_role_id # role assigned on whitelist
